# Copy this file to .env and fill in values for your deployment.
# docker-compose.yml / docker-compose.truenas.yml read these at startup.

# --- Storage paths -----------------------------------------------------
# Host directory mounted at /app/data (document backups + uploads).
# docker-compose.yml defaults this to ./data if unset.
# docker-compose.truenas.yml has no default -- you must set it (e.g. a
# TrueNAS dataset path such as /mnt/pool1/localrag/knowledge).
KNOWLEDGE_DATA_PATH=./data

# Host directory mounted at /data for the Redis Stack volume.
# Only used by docker-compose.truenas.yml (docker-compose.yml uses a
# named Docker volume by default).
REDIS_DATA_PATH=/mnt/pool1/localrag/redis

# --- Security ------------------------------------------------------------
# Required. Signs session tokens for account login (Vaultly multi-user
# accounts) -- the app will not start without this set. Generate with:
#   openssl rand -hex 32
JWT_SECRET=

# Comma-separated list of origins allowed to call the backend API.
CORS_ALLOWED_ORIGINS=http://localhost:3000
