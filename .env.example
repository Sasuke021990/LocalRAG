# Copy this file to .env and fill in values for your deployment.
# docker-compose.yml / docker-compose.truenas.yml read these at startup.

# --- Storage paths -----------------------------------------------------
# Host directory mounted at /app/data (document backups + uploads).
# docker-compose.yml defaults this to ./data if unset.
# docker-compose.truenas.yml has no default -- you must set it (e.g. a
# TrueNAS dataset path such as /mnt/pool1/localrag/knowledge).
KNOWLEDGE_DATA_PATH=./data

# Host directory mounted at /data for the Redis Stack volume.
# Only used by docker-compose.truenas.yml (docker-compose.yml uses a
# named Docker volume by default).
REDIS_DATA_PATH=/mnt/pool1/localrag/redis

# --- Security ------------------------------------------------------------
# Required. Signs session tokens for account login (Vaultly multi-user
# accounts) -- the app will not start without this set. Generate with:
#   openssl rand -hex 32
JWT_SECRET=

# Required. Password for the Redis instance (redis --requirepass). Redis holds
# every tenant's password hashes, tokens, and PII, so it must never run
# unauthenticated. The docker-compose files set this on both the redis server
# and the backend, and refuse to start without it. Generate with:
#   openssl rand -hex 32
REDIS_PASSWORD=

# Comma-separated list of origins allowed to call the backend API.
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Base URL of the frontend -- used to build links (password reset,
# post-OAuth-login redirect) that need to point at the browser app.
FRONTEND_BASE_URL=http://localhost:3000

# Set to true ONLY when the API sits behind a trusted reverse proxy that sets
# X-Forwarded-For. It makes the auth rate limiter use the forwarded client IP
# instead of the socket peer. Leaving it false when there's no trusted proxy
# prevents clients from spoofing the header to evade rate limits.
TRUST_PROXY_HEADERS=false

# /docs + /redoc (Swagger/ReDoc) publish the full API surface --
# unauthenticated. Fine for local/homelab use; set to false for any
# internet-facing deployment that doesn't need public API docs.
API_DOCS_ENABLED=true

# Auth rate limiting (Redis-backed, per client IP). Leave enabled in every
# real environment; the defaults below allow normal use while throttling
# brute force / credential stuffing / mass signup / reset spam.
RATE_LIMIT_ENABLED=true
RATE_LIMIT_LOGIN_MAX=10
RATE_LIMIT_LOGIN_WINDOW=60
RATE_LIMIT_SIGNUP_MAX=5
RATE_LIMIT_SIGNUP_WINDOW=3600
RATE_LIMIT_RESET_MAX=5
RATE_LIMIT_RESET_WINDOW=3600

# Seconds of no mouse/keyboard/touch/scroll activity before the frontend
# shows a "still there?" popup; unanswered for another window of the same
# length, the user is force-logged-out. Does not change how long the
# underlying session cookie itself lasts (SESSION_COOKIE_MAX_AGE_SECONDS).
SESSION_IDLE_TIMEOUT_SECONDS=60

# Email of the operator/admin account. A signed-in user whose email
# matches this gets access to the metadata-only admin panel (/admin/*).
# Leave blank to designate no env-level admin (admins can still be
# promoted by an existing admin). The admin panel never exposes any
# user's document content -- only account metadata and counts.
ADMIN_EMAIL=

# Required alongside ADMIN_EMAIL to seed a default admin account on startup
# (create-if-missing) -- set both to have someone who can log in immediately
# on a fresh install. If ADMIN_EMAIL is set but this is left blank, seeding
# is skipped (with a warning): a randomly-generated password is deliberately
# NOT auto-created here, since it would have to be printed to the startup
# logs to be usable -- container logs routinely end up in a log aggregator
# or support ticket, which is not where a real credential belongs. Leave
# both blank to seed no account; an existing admin can always promote
# another user from the admin panel instead.
ADMIN_PASSWORD=

# --- Google OAuth ("Sign in with Google") --------------------------------
# Optional. Leave blank to disable Google login (email/password still
# works). Register an OAuth app at https://console.cloud.google.com/ and
# set the redirect URI there to match GOOGLE_REDIRECT_URI below.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# --- SMTP (password reset email) ------------------------------------------
# Optional. Leave blank to disable password-reset emails (the request
# endpoint still responds successfully -- it just won't send anything).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@vaultly.local
SMTP_USE_TLS=True

# --- Billing / plan limits (INR) ------------------------------------------
# Per-plan storage allowances (GB). Free/Pro/Max.
FREE_STORAGE_GB=1
PRO_STORAGE_GB=5
MAX_STORAGE_GB=15
# Per-user AI question allowance per day. Max is "unlimited" plan-wide but
# still capped per individual user.
FREE_AI_QUESTIONS_PER_DAY=10
PRO_AI_QUESTIONS_PER_DAY=25
MAX_AI_QUESTIONS_PER_DAY_PER_USER=30
# Prices in whole rupees (monthly / annual).
PRO_PRICE_MONTHLY_INR=59
PRO_PRICE_ANNUAL_INR=600
MAX_PRICE_MONTHLY_INR=79
MAX_PRICE_ANNUAL_INR=800
# Max team members that can share a Max-plan workspace.
MAX_PLAN_TEAM_MEMBERS=5
# Saved-conversation caps per plan. Starting a new chat past the cap
# auto-deletes the user's least-recently-touched conversation to make room
# (no blocking/upgrade nag). <= 0 means unlimited. Admin/operator accounts
# are always exempt.
FREE_CONVERSATION_LIMIT=5
PRO_CONVERSATION_LIMIT=15
MAX_CONVERSATION_LIMIT=20

# --- Webhook delivery -----------------------------------------------------
# Tuning for outbound webhook delivery (document lifecycle events). Each
# delivery is attempted up to WEBHOOK_MAX_RETRIES times with a
# WEBHOOK_TIMEOUT_SECONDS per-attempt timeout.
WEBHOOK_MAX_RETRIES=3
WEBHOOK_TIMEOUT_SECONDS=5

# --- Local AI answers (grounded LLM) ------------------------------------
# Off by default. When true, a local GGUF model generates answers strictly
# from the user's own retrieved documents (with a refusal gate — it says it
# can't find the answer rather than making one up). Downloads once (~1GB)
# into the models volume on first startup; needs ~2.5GB RAM headroom.
LLM_ENABLED=False
# How generation runs:
#   embedded — in-process llama.cpp, one answer at a time (simple; a few users).
#   openai   — stream from an external OpenAI-compatible inference server
#              (Ollama / vLLM / TGI) that batches concurrent requests. This is
#              the scaling path — no in-process model/lock, backend workers stay
#              stateless, so you can run several replicas behind the same server.
LLM_BACKEND=embedded
# --- openai backend only ---
LLM_API_BASE=http://localhost:11434/v1
LLM_API_KEY=
LLM_MODEL=qwen2.5:1.5b-instruct
# Vision model on the same server, used only to OCR/describe images at upload
# time (chat itself never calls it). Needs a model that accepts image_url
# content — an OCR or VL (vision+language) model.
LLM_VISION_MODEL=glm-ocr
# Cap simultaneous streams opened from this process (protects the server).
LLM_MAX_CONCURRENCY=8
# --- embedded backend only ---
# The model — any GGUF under your RAM budget. Change these two to swap it.
LLM_MODEL_REPO=Qwen/Qwen2.5-1.5B-Instruct-GGUF
LLM_MODEL_FILE=qwen2.5-1.5b-instruct-q4_k_m.gguf
# Reasoning: when true the model thinks in a <think></think> block before the
# answer (best with a thinking-capable model, e.g. a Qwen3 GGUF); the UI shows
# that reasoning in a separate collapsible section.
LLM_THINKING_ENABLED=False
LLM_CONTEXT_SIZE=4096
LLM_MAX_TOKENS=512
LLM_THREADS=0
LLM_TEMPERATURE=0.0
# Refusal gate: if the top reranked relevance score is below this, the model is
# never called and a fixed "not in your documents" message is returned.
LLM_MIN_RELEVANCE_SCORE=0.0
# TrueNAS only: dataset path for downloaded model weights.
MODELS_DATA_PATH=./models
